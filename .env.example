# ── Database (PostgreSQL) ────────────────────────────────
POSTGRES_USER=eduagent
POSTGRES_PASSWORD=eduagent_dev
POSTGRES_DB=eduagent
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Database (Neo4j) ────────────────────────────────────
NEO4J_AUTH=neo4j/eduagent_dev
NEO4J_PASSWORD=eduagent_dev
NEO4J_URI=bolt://neo4j:7687

# ── Database (Redis) ────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Database (MongoDB for LTI) ──────────────────────────
MONGODB_URL=mongodb://mongo:27017/lti

# ── Vector DB (Milvus on host) ───────────────────────────
MILVUS_HOST=host.docker.internal
MILVUS_PORT=19530

# ── LLM ──────────────────────────────────────────────────
LLM_BASE_URL=https://codex-api.inspiredjinyao.com
LLM_API_KEY=your_api_key_here
LLM_MODEL=gpt-5.4

# ── Auth (JWT) ───────────────────────────────────────────
JWT_SECRET=change_me_in_production
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES=1440

# ── Frontend ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://backend:8000
BACKEND_URL=http://backend:8000

# ── LTI Provider ────────────────────────────────────────
LTI_KEY=ltijs_key
FRONTEND_URL=http://frontend:3001
# LTI_PLATFORM_URL=https://mooc1.chaoxing.com
# LTI_CLIENT_ID=CHAOXING_CLIENT_ID
# LTI_AUTH_ENDPOINT=https://mooc1.chaoxing.com/auth
# LTI_TOKEN_ENDPOINT=https://mooc1.chaoxing.com/token
# LTI_KEYSET_URL=https://mooc1.chaoxing.com/.well-known/jwks.json
